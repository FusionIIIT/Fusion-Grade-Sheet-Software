{
  "name": "fusion-grade-sheet",
  "version": "1.0.13",
  "description": "Offline desktop app to generate IIITDM Jabalpur grade-sheet PDFs from an approval sheet",
  "author": "PDPM IIITDM Jabalpur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FusionIIIT/Fusion-Grade-Sheet-Software.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "icon": "node scripts/make-icon.mjs",
    "test": "node scripts/selftest.mjs && node scripts/test-filename.mjs && node scripts/test-grid.mjs && node scripts/test-multitab.mjs && node scripts/test-summer-empty.mjs",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@mantine/core": "^7.13.4",
    "@mantine/hooks": "^7.13.4",
    "@mantine/notifications": "^7.13.4",
    "@tabler/icons-react": "^3.19.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.1",
    "vite": "^5.4.8"
  }
}
